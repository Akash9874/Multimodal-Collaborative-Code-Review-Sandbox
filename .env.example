# apps/web (inlined at build time)
NEXT_PUBLIC_SYNC_URL=ws://localhost:1234/sync
NEXT_PUBLIC_EXEC_URL=ws://localhost:1234/exec

# apps/ws-server
PORT=1234
HOST=0.0.0.0

# A self-hosted Piston: `pnpm piston:up`. The public instance (emkc.org) became whitelist-only
# on 2026-02-15 — GET /runtimes still answers, POST /execute returns 401.
PISTON_URL=http://localhost:2000/api/v2

# Set false to advertise that this server cannot execute code, so Run explains itself instead of
# failing on click. The hosted demo sets false; local development leaves it unset.
EXECUTION_ENABLED=true

# Room persistence. Unset → rooms live in memory and die with the process.
# Use a DEVELOPMENT database when running tests: the TTL sweep the Postgres suite exercises is
# global, and deletes any room older than its cutoff.
#
# Local (`pnpm db:up` boots it and migrates it):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
#
# Supabase — the Session pooler string (port 5432), then `pnpm db:migrate` once:
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# How long a room lingers in memory after its last client leaves (ms). The e2e run shortens this.
ROOM_GRACE_MS=30000
# Rooms untouched for this many days are deleted on boot.
ROOM_TTL_DAYS=30
